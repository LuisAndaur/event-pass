{
  "__inputs": [],
  "__elements": {},
  "__requires": [],
  "title": "EventPass — Overview",
  "description": "Monitoreo general del sistema de eventos",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "panels": [
    {
      "title": "Health Status",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up{job=~\"gateway|waiting-room|catalog|reservation\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "title": "HTTP Requests / sec",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[1m])",
          "legendFormat": "{{service}} - {{method}}"
        }
      ]
    },
    {
      "title": "JVM Memory Usage",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"} / 1024 / 1024",
          "legendFormat": "{{service}} heap (MB)"
        }
      ]
    },
    {
      "title": "HTTP Error Rate (4xx/5xx)",
      "type": "graph",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m])",
          "legendFormat": "{{service}} - {{status}}"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "time": { "from": "now-15m", "to": "now" }
}
